{
  "name": "Cardmarket Wants Lists Helper",
  "description": "A extension to help with managing Magic: The Gathering wants lists on Cardmarket.",
  "version": "1.3.0",
  "manifest_version": 3,
  "permissions": [
    "clipboardWrite",
    "clipboardRead",
    "storage"
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "host_permissions": [
    "https://www.cardmarket.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "iconI16.png",
      "32": "iconI32.png",
      "48": "iconI48.png",
      "128": "iconI128.png"
    }
  },
  "popup_pages": [
    "how-it-works.html"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.cardmarket.com/*/Magic/Users/*"
      ],
      "js": [
        "usersHelpers.js"
      ]
    },
    {
      "matches": [
        "https://www.cardmarket.com/*/Magic/*"
      ],
      "js": [
        "loginReminder.js"
      ]
    },
    {
      "matches": [
        "https://www.cardmarket.com/*/Magic/Wants/*"
      ],
      "exclude_matches": [
        "https://www.cardmarket.com/*/Magic/Wants/*/AddDeckList*"
      ],
      "js": [
        "wantsCopyHelpers.js"
      ],
      "css": [
        "styles.css"
      ]
    },
    {
      "matches": [
        "https://www.cardmarket.com/*/Magic/Wants/*/AddDeckList"
      ],
      "js": [
        "wantsAddHelpers.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "utils/encrypt.js",
        "utils/parser.js",
        "utils/toast.js",
        "utils/cachedFetch.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}